# infraforge local development environment variables
# Copy to .env and fill in real values before running `docker compose --profile full up`

# GitHub OAuth App (required for UI login)
# Create at: https://github.com/settings/developers → OAuth Apps → New OAuth App
# Homepage URL: http://localhost:3000
# Callback URL: http://localhost:3000/api/auth/callback/github
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# NextAuth session encryption key (generate with: openssl rand -base64 32)
AUTH_SECRET=replace-with-openssl-rand-base64-32-output

# The following are pre-set for local docker compose and do not need changes:
# INFRAFORGE_SERVICE_KEY=local-service-key
# INFRAFORGE_JWT_SECRET=local-dev-jwt-secret-min-32-chars-xxxx
# USE_FAKE_LLM=true   (agent uses canned LLM responses; no AWS Bedrock needed)
